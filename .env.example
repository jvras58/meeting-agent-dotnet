ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:5080

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# IA
# heuristic = fallback local sem modelo real
# ollama = usa o container/serviço Ollama
AI_PROVIDER=heuristic
AI_MODEL=qwen3:8b

# Dentro do compose.dev.yml, o serviço dotnet_dev usa http://ollama:11434.
# Rodando direto no host, use http://localhost:11434.
AI_BASE_URL=http://ollama:11434

# Modelos locais podem demorar na primeira geração ou em CPUs mais fracas.
AI_TIMEOUT_SECONDS=300

# Persistência compartilhada entre API e Worker
DATABASE_PROVIDER=postgres
DATABASE_URL=Host=postgres;Port=5432;Database=meeting_agent;Username=postgres;Password=postgres

REDIS_URL=redis:6379

# Fila de processamento assíncrono
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE=meeting.processing.requested

BLOB_STORAGE_PROVIDER=local
BLOB_STORAGE_PATH=./data/storage

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
